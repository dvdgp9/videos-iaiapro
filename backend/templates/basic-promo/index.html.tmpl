<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width={{width}}, height={{height}}" />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body {
            width: {{width}}px;
            height: {{height}}px;
            overflow: hidden;
            background: {{primary_color}};
            font-family: -apple-system, "Segoe UI", Inter, Roboto, sans-serif;
            color: {{text_color}};
        }

        #root { position: relative; width: 100%; height: 100%; }

        /* Main image acts as the backdrop, dimmed by an overlay */
        #bg-image {
            position: absolute; inset: 0;
            background-size: cover;
            background-position: center;
            opacity: 0;
        }
        #bg-image[data-src=""] { display: none; }

        #bg-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(180deg,
                color-mix(in srgb, {{primary_color}} 92%, transparent) 0%,
                color-mix(in srgb, {{primary_color}} 70%, transparent) 60%,
                color-mix(in srgb, {{primary_color}} 95%, transparent) 100%
            );
        }

        /* Top bar: logo + brand name */
        #top-bar {
            position: absolute;
            top: 5%; left: 5%;
            display: flex; align-items: center; gap: 24px;
            opacity: 0;
        }
        #logo {
            height: clamp(48px, 8vh, 96px);
            width: auto;
        }
        #logo[src=""] { display: none; }
        #brand-name {
            font-size: clamp(18px, 2.4vh, 32px);
            font-weight: 600;
            letter-spacing: 0.02em;
            opacity: 0.9;
        }
        #brand-name:empty { display: none; }

        /* Main content block */
        #main {
            position: absolute;
            left: 5%; right: 5%;
            top: 50%;
            transform: translateY(-50%);
            max-width: 90%;
        }

        #title {
            font-size: clamp(42px, 8vh, 120px);
            font-weight: 800;
            line-height: 1.05;
            letter-spacing: -0.01em;
            opacity: 0;
        }
        #title::after {
            content: "";
            display: block;
            width: 0;
            height: 6px;
            background: {{secondary_color}};
            margin-top: 0.4em;
            border-radius: 3px;
        }

        #subtitle {
            margin-top: 1em;
            font-size: clamp(22px, 3.4vh, 44px);
            font-weight: 400;
            line-height: 1.3;
            opacity: 0;
            max-width: 85%;
        }
        #subtitle:empty { display: none; }

        /* CTA */
        #cta {
            position: absolute;
            bottom: 8%;
            left: 5%;
            padding: 18px 36px;
            background: {{secondary_color}};
            color: {{primary_color}};
            font-size: clamp(20px, 3vh, 36px);
            font-weight: 700;
            border-radius: 999px;
            opacity: 0;
        }
        #cta:empty { display: none; }
    </style>
</head>
<body>

<div id="root"
     data-composition-id="main"
     data-start="0"
     data-duration="{{duration}}"
     data-width="{{width}}"
     data-height="{{height}}">

    <div id="bg-image" data-src="{{asset_main_image}}"></div>
    <div id="bg-overlay"></div>

    <div id="top-bar">
        <img id="logo" src="{{asset_logo}}" alt="" />
        <div id="brand-name">{{brand_name}}</div>
    </div>

    <div id="main">
        <h1 id="title">{{title}}</h1>
        <div id="subtitle">{{subtitle}}</div>
    </div>

    <div id="cta">{{cta}}</div>
</div>

<script>
    // Apply main image as background via JS so the CSS cascade works with the data-src pattern.
    (function () {
        var el = document.getElementById('bg-image');
        var src = el.getAttribute('data-src');
        if (src) {
            el.style.backgroundImage = 'url("' + src + '")';
        }
    })();

    window.__timelines = window.__timelines || {};
    var tl = gsap.timeline({ paused: true });

    // 0-1s: background image fades in
    tl.to('#bg-image', { opacity: 1, duration: 1.0, ease: 'power2.out' }, 0);

    // 0.4-1.6s: top bar slides down
    tl.from('#top-bar', { y: -60, duration: 1.0, ease: 'power3.out' }, 0.4);
    tl.to(  '#top-bar', { opacity: 1, duration: 0.6, ease: 'power2.out' }, 0.4);

    // 1.5-3s: title fades + slides up, underline grows
    tl.from('#title', { y: 40, duration: 1.0, ease: 'power3.out' }, 1.5);
    tl.to(  '#title', { opacity: 1, duration: 0.8, ease: 'power2.out' }, 1.5);
    tl.to(  '#title::after', {}, 2.2); // placeholder — pseudo animated via CSS below
    tl.to(  {}, { duration: 0.01, onComplete: function () {
        // animate underline width via CSS custom prop trick
        var style = document.createElement('style');
        style.textContent = '#title::after { transition: width 0.9s cubic-bezier(.2,.8,.2,1); width: 35%; }';
        document.head.appendChild(style);
    }}, 2.2);

    // 2.4-3.6s: subtitle
    tl.from('#subtitle', { y: 20, duration: 0.8, ease: 'power2.out' }, 2.4);
    tl.to(  '#subtitle', { opacity: 1, duration: 0.7, ease: 'power2.out' }, 2.4);

    // 4-5s: CTA scales in
    tl.from('#cta', { scale: 0.7, duration: 0.6, ease: 'back.out(1.4)' }, 4.0);
    tl.to(  '#cta', { opacity: 1, duration: 0.5, ease: 'power2.out' }, 4.0);

    // 5-{{duration}}: gentle pulse on CTA
    tl.to('#cta', {
        scale: 1.05,
        duration: 0.6,
        yoyo: true,
        repeat: 4,
        ease: 'sine.inOut'
    }, 5.0);

    // Final fade of content to let background breathe (last 0.8s)
    var endFade = Math.max({{duration}} - 0.8, 6);
    tl.to(['#title', '#subtitle'], { opacity: 0.85, duration: 0.8, ease: 'power2.in' }, endFade);

    window.__timelines['main'] = tl;
</script>

</body>
</html>
