# Copy to .env and fill in values. Never commit .env.

APP_ENV=local
APP_URL=http://localhost:8000
APP_DEBUG=true
# Used for CSRF/HMAC derivation and other signed values. REQUIRED in production.
# Generate with: openssl rand -hex 32
APP_SECRET=change-me-to-a-long-random-hex

# Auth
REGISTRATION_ENABLED=true

# MariaDB / MySQL (on VPS, MariaDB 11 local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dvdgp_videos
DB_USER=dvdgp_vid_usr
DB_PASS=replace-me

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_REFERRER=https://videos.iaiapro.com
OPENROUTER_TITLE=videos.iaiapro.com

# Render worker (Node service wrapping Hyperframes, internal only).
# URL is used by PHP to reach the worker; must match host:port below.
RENDER_API_URL=http://127.0.0.1:3001
RENDER_API_PORT=3001
# Shared secret between PHP and Node. Generate with: openssl rand -hex 32
RENDER_API_TOKEN=change-me-to-a-long-random-hex

# Render defaults (worker). Conservative for small VPS (2 cores, 3.7 GB RAM).
RENDER_WORKERS=1
RENDER_QUALITY=standard
RENDER_FPS=30
RENDER_FORMAT=mp4
RENDER_TIMEOUT_MS=600000

# Data dirs on the VPS (must exist and be writable by the dvdgp user).
PROJECTS_DIR=/home/dvdgp/data/videos/projects
RENDERS_DIR=/home/dvdgp/data/videos/renders
TEMP_DIR=/home/dvdgp/data/videos/temp

# Session
SESSION_NAME=viaiapro_sess
SESSION_LIFETIME_MINUTES=120
