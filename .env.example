# Copy to .env and fill in values. Never commit .env.

APP_ENV=local
APP_URL=http://localhost:8000
APP_DEBUG=true

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=videos_iaiapro
DB_USER=root
DB_PASS=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_REFERRER=https://videos.iaiapro.com
OPENROUTER_TITLE=videos.iaiapro.com

# Render API (Node service wrapping Hyperframes, running in Hetzner VPS)
RENDER_API_URL=http://127.0.0.1:4000
RENDER_API_TOKEN=change-me

# Session
SESSION_NAME=viaiapro_sess
SESSION_LIFETIME_MINUTES=120
